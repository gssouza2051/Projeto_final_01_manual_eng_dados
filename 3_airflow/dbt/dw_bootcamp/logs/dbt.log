        stg.weather_delay,
        stg.nas_delay,
        stg.security_delay,
        stg.late_aircraft_delay,

        -- contagens por causa (ocorrências)
        stg.carrier_ct,
        stg.weather_ct,
        stg.nas_ct,
        stg.security_ct,
        stg.late_aircraft_ct

    from stg
)

select * from fct
  );
  
